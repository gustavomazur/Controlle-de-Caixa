# ===========================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ===========================================

# Perfil ativo da aplicação
# Valores possíveis: dev, docker
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# CONFIGURAÇÕES DO CLOUNDINARY
# ===========================================

# Substitua pelas suas credenciais do Cloudinary
# Obtenha em: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=SUA_CLOUD_NAME
CLOUDINARY_API_KEY=SUA_API_KEY
CLOUDINARY_API_SECRET=SUA_API_SECRET

# ===========================================
# CONFIGURAÇÕES DO BANCO DE DADOS (DEV)
# ===========================================

# Credenciais para desenvolvimento local
SPRING_DATASOURCE_URL_DEV=jdbc:mysql://localhost:3306/controle_venda?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME_DEV=SEU_USUARIO_MYSQL
SPRING_DATASOURCE_PASSWORD_DEV=SUA_SENHA_MYSQL

# ===========================================
# CONFIGURAÇÕES DO BANCO DE DADOS (DOCKER)
# ===========================================

# Credenciais para ambiente Docker
SPRING_DATASOURCE_URL_DOCKER=jdbc:mysql://localhost:3307/contador_loja?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME_DOCKER=SEU_USUARIO_DOCKER
SPRING_DATASOURCE_PASSWORD_DOCKER=SUA_SENHA_DOCKER

# ===========================================
# CONFIGURAÇÕES JPA/HIBERNATE
# ===========================================

# Estratégia de DDL (create, update, validate, none)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
